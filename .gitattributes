# Normalize line endings to LF on commit (works correctly on Windows, macOS, Linux)
* text=auto eol=lf

# Python source
*.py text eol=lf
*.kv text eol=lf

# Config / data
*.json text eol=lf
*.csv  text eol=lf
*.spec text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary — never diff or merge
*.apk  binary
*.dex  binary
*.so   binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.tar  binary
*.gz   binary

# Mark APK for Git LFS (optional — uncomment if using LFS)
# *.apk filter=lfs diff=lfs merge=lfs -text
