<LiveDataScreen>:
    BoxLayout:
        orientation: 'vertical'
        
        # --- Top Control Bar ---
        BoxLayout:
            size_hint_y: None
            height: '80dp'
            padding: '5dp'
            spacing: '5dp'
            canvas.before:
                Color:
                    rgba: 0.15, 0.15, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "Back"
                size_hint_x: 0.15
                on_release: root.manager.current = 'selection'
            
            Button:
                text: "Stream" if not root.is_streaming else "Stop"
                on_release: root.toggle_streaming()
                background_color: (0, 0.7, 0, 1) if not root.is_streaming else (0.7, 0, 0, 1)

            Button:
                text: "Record" if not root.is_recording else "Stop Rec"
                on_release: root.toggle_recording()
            
            # Contraction Indicator
            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.2
                Label:
                    text: "●"
                    color: root.contraction_color
                    font_size: '30sp'
                Label:
                    text: root.contraction_text
                    font_size: '10sp'

            Label:
                text: root.battery_text
                color: root.battery_color
                size_hint_x: 0.15

        # --- Main Tabs Area ---
        TabbedPanel:
            id: tabs
            do_default_tab: False
            
            TabbedPanelItem:
                text: "Tracks"
                ScrollView:
                    BoxLayout:
                        id: all_tracks_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height

            TabbedPanelItem:
                text: "Heatmap"
                HeatmapWidget: # Custom widget for the 8x8 grid
                    id: heatmap_widget

            TabbedPanelItem:
                text: "Features"
                ScrollView:
                    BoxLayout:
                        id: features_layout
                        orientation: 'vertical'
                        size_hint_y: None
                        height: self.minimum_height

        # --- Footer Status ---
        Label:
            size_hint_y: None
            height: '30dp'
            text: root.status_text
            font_size: '12sp'